{
	"name": "kobalte-monorepo",
	"version": "0.0.0",
	"private": true,
	"description": "A UI toolkit for building SolidJS applications.",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kobaltedev/kobalte.git"
	},
	"license": "MIT",
	"author": "jer3m01 <jer3m01@jer3m01.com>",
	"contributors": [
		"Fabien Marie-Louise <fabienml.dev@gmail.com>"
	],
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"build": "turbo run build",
		"build:libs": "pnpm -F \\!docs -F \\!playground build && pnpm i",
		"changeset": "changeset",
		"ci:release": "pnpm build && changeset publish",
		"ci:version": "changeset version && pnpm i --no-frozen-lockfile && git add .",
		"clean": "turbo run clean && rm -rf node_modules",
		"commit": "git-cz",
		"dev:core": "pnpm -F @kobalte/core dev",
		"dev:docs": "pnpm -F @kobalte/docs dev",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"format": "biome check --write && prettier . --write",
		"check": "biome check",
		"test": "turbo run test",
		"typecheck": "turbo run typecheck"
	},
	"config": {
		"commitizen": {
			"path": "@commitlint/cz-commitlint"
		}
	},
	"devDependencies": {
		"@babel/core": "7.22.10",
		"@babel/preset-env": "7.22.10",
		"@biomejs/biome": "1.8.1",
		"@changesets/cli": "2.26.2",
		"@commitlint/cli": "17.7.1",
		"@commitlint/config-conventional": "17.7.0",
		"@commitlint/cz-commitlint": "17.7.1",
		"@solidjs/testing-library": "0.8.6",
		"@solidjs/web": "2.0.0-beta.14",
		"@storybook/addon-docs": "^10.4.1",
		"@testing-library/dom": "9.3.4",
		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/user-event": "14.5.2",
		"@types/node": "20.5.4",
		"@vitest/ui": "^2.1.9",
		"autoprefixer": "10.4.15",
		"babel-preset-solid": "2.0.0-beta.14",
		"commitizen": "4.3.0",
		"inquirer": "8.2.5",
		"jsdom": "25.0.1",
		"postcss": "8.4.28",
		"prettier": "4.0.0-alpha.10",
		"prettier-plugin-tailwindcss": "0.5.3",
		"rollup": "4.62.2",
		"rollup-plugin-cleanup": "3.2.1",
		"rollup-plugin-copy": "3.5.0",
		"rollup-plugin-license": "3.7.1",
		"rollup-preset-solid": "2.0.1",
		"solid-js": "2.0.0-beta.14",
		"storybook": "^10.4.1",
		"storybook-solidjs-vite": "^10.1.0",
		"tailwindcss": "3",
		"tsup": "7.2.0",
		"turbo": "1.10.13",
		"typescript": "6.0.3",
		"vite": "^6.3.5",
		"vite-plugin-solid": "3.0.0-next.5",
		"vitest": "2.1.9"
	},
	"pnpm": {
		"overrides": {
			"@solid-primitives/controlled-signal": "link:/Users/ddibiase/Projects/solid-primitives/packages/controlled-signal",
		  "@solid-primitives/utils": "link:/Users/ddibiase/Projects/solid-primitives/packages/utils",
			"@solid-primitives/event-listener": "link:/Users/ddibiase/Projects/solid-primitives/packages/event-listener",
			"@solid-primitives/keyed": "link:/Users/ddibiase/Projects/solid-primitives/packages/keyed",
			"@solid-primitives/map": "link:/Users/ddibiase/Projects/solid-primitives/packages/map",
			"@solid-primitives/media": "link:/Users/ddibiase/Projects/solid-primitives/packages/media",
			"@solid-primitives/props": "link:/Users/ddibiase/Projects/solid-primitives/packages/props",
			"@solid-primitives/refs": "link:/Users/ddibiase/Projects/solid-primitives/packages/refs",
			"@solid-primitives/resize-observer": "link:/Users/ddibiase/Projects/solid-primitives/packages/resize-observer",
			"@solid-primitives/trigger": "link:/Users/ddibiase/Projects/solid-primitives/packages/trigger",
			"@solid-primitives/rootless": "link:/Users/ddibiase/Projects/solid-primitives/packages/rootless",
			"@solid-primitives/static-store": "link:/Users/ddibiase/Projects/solid-primitives/packages/static-store"
		},
		"patchedDependencies": {
			"@solidjs/testing-library@0.8.6": "patches/@solidjs__testing-library@0.8.6.patch"
		}
	},
	"packageManager": "pnpm@9.12.3"
}
