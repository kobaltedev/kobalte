{
	"name": "@kobalte/utils",
	"version": "0.9.1",
	"private": false,
	"description": "Common utilities and types for Kobalte.",
	"keywords": [
		"solid",
		"solidjs",
		"ui",
		"library",
		"design-system",
		"components",
		"headless",
		"unstyled",
		"aria"
	],
	"homepage": "https://github.com/kobaltedev/kobalte/tree/main/packages/utils#readme",
	"bugs": {
		"url": "https://github.com/kobaltedev/kobalte/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kobaltedev/kobalte.git"
	},
	"license": "MIT",
	"author": "Fabien Marie-Louise <fabienml.dev@gmail.com>",
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"solid": "./dist/index.js",
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": "./dist/index.cjs"
		},
		"./src/*": "./src/*"
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"source": "src/index.ts",
	"files": [
		"dist",
		"src"
	],
	"scripts": {
		"build": "tsup",
		"clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@solid-primitives/event-listener": "next",
		"@solid-primitives/keyed": "next",
		"@solid-primitives/map": "next",
		"@solid-primitives/media": "next",
		"@solid-primitives/props": "next",
		"@solid-primitives/refs": "next",
		"@solid-primitives/utils": "next"
	},
	"peerDependencies": {
		"@solidjs/web": "^2.0.0-beta.14",
		"solid-js": "^2.0.0-beta.14"
	},
	"publishConfig": {
		"access": "public"
	}
}
